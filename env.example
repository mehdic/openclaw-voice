# OpenClaw Voice config
# Copy to .env and fill in your values

# ── OpenClaw Gateway ──
OPENCLAW_URL=http://localhost:18789
OPENCLAW_TOKEN=

# ── LiveKit ──
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ── STT ──
# Local Whisper is the default (no key needed)
# STT_MODEL_SIZE=small
# STT_LANGUAGE=en

# ── TTS ──
ELEVEN_API_KEY=
# ELEVEN_VOICE_ID=pNInz6obpgDQGcFmaJgB

# ── Auth ──
# GOOGLE_CLIENT_ID=
# AUTHORIZED_EMAILS=you@example.com
# AUTH_MODE=demo

# ── Server ──
# WEB_PORT=7890
# SESSION_SECRET=
